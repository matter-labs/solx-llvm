  ; CHECK-NEXT: bb.2:
  ; CHECK-NEXT:   successors: %bb.4(0x40000000), %bb.5(0x40000000)
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT:   JUMPI %bb.4, [[ARGUMENT]], implicit-def $arguments
  ; CHECK-NEXT:   JUMP %bb.5, implicit-def $arguments
