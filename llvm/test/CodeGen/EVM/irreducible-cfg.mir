# Test in which an outer irreducible cycle contains an irreducible child cycle
# whose entry is also an entry of the parent cycle.
# This test exposes issue when using CycleAnalysis and updating it on the fly
# as FixIrreducible.cpp does, in which case assert inside CycleAnalysis fails.

---
name:            irreducible_parent_rewrites_child_entry
alignment:       1
tracksRegLiveness: true
isSSA:           false
body:             |
  ; CHECK-LABEL: name: irreducible_parent_rewrites_child_entry
  ; CHECK: bb.0:
  ; CHECK-NEXT:   successors: %bb.1(0x40000000), %bb.7(0x40000000)
  ; CHECK-NEXT:   liveins: $arguments
  ; CHECK-NEXT: {{  $}}
