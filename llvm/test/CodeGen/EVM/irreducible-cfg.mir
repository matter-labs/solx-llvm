  ; CHECK-NEXT:   JUMP %bb.6, implicit-def $arguments
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT: bb.8:
  ; CHECK-NEXT:   successors: %bb.6(0x80000000)
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT:   [[DEF:%[0-9]+]]:gpr = CONST_I256 i256 0, implicit-def $arguments
  ; CHECK-NEXT:   JUMP %bb.6, implicit-def $arguments
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT: bb.9:
