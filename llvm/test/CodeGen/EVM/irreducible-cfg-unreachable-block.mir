# NOTE: Assertions have been autogenerated by utils/update_mir_test_checks.py UTC_ARGS: --version 5
# RUN: llc -x mir -run-pass=unreachable-mbb-elimination,evm-fix-irreducible-control-flow -verify-machineinstrs < %s | FileCheck %s

# In case we don't remove unreachable block before fixing irreducible control flow,
# the following assertion will fail in EVMFixIrreducibleControlFlow.cpp:
#   Assertion failed: (Node.SCCId != std::numeric_limits<unsigned>::max())

--- |
  target datalayout = "E-p:256:256-i256:256:256-S256-a:256:256"
  target triple = "evm-unknown-unknown"

  define void @unreachable_block() {
  entry:
    ret void
  }

...
---
name:            unreachable_block
alignment:       1
tracksRegLiveness: true
isSSA:           false
body:             |
  ; CHECK-LABEL: name: unreachable_block
  ; CHECK: bb.0:
  ; CHECK-NEXT:   liveins: $arguments
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT:   RET implicit-def $arguments
  bb.0:
    liveins: $arguments
    RET implicit-def $arguments

  bb.1:
    RET implicit-def $arguments
...
